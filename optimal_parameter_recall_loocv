import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import RandomForestClassifier
from sklearn.linear_model import LogisticRegression
from sklearn.svm import SVC
from sklearn.neural_network import MLPClassifier
from sklearn.tree import DecisionTreeClassifier
from sklearn.naive_bayes import GaussianNB
from sklearn.neighbors import KNeighborsClassifier
from sklearn.model_selection import RandomizedSearchCV
from scipy.stats import uniform as sp_randFloat
from scipy.stats import randint as sp_randInt
from sklearn.model_selection import LeaveOneOut

loo = LeaveOneOut()

# Load data
data = pd.read_excel('synthetic_polymer_gram-positive_ratio_limit.xlsx')
X = data.drop(columns=['MIC_64', 'MIC_128'])
Y = data['MIC_64']

# Standardize data
sc = StandardScaler()
X_scaled = sc.fit_transform(X)
X_scaled = pd.DataFrame(X_scaled, columns = X.columns, index = X.index.values.tolist())
X = X_scaled.to_numpy()

# Split data
X_train, X_test, Y_train, Y_test = train_test_split(X_scaled, Y, test_size=0.3, random_state=0, stratify=Y)

# Define classifiers and their parameters
parameters = {'n_estimators': sp_randInt(20,450),
              'min_samples_split': sp_randInt(2,10),
              'min_samples_leaf': sp_randInt(2,10),
              'class_weight': ['balanced', 'balanced_subsample', 'None'],
              'max_features': ['log2', 'sqrt'],
              'max_depth': sp_randInt(3,30) or None,
              'criterion': ['entropy', 'gini', 'log_loss']
              }
print("Random Forest Classifier")

random_search = RandomizedSearchCV(estimator=RandomForestClassifier(random_state=0, bootstrap=True),
                                   param_distributions=parameters,
                                   scoring ="f1",
                                   cv = loo,
                                   n_iter= 100,
                                   n_jobs=-1)

random_search.fit(X_train, Y_train)
best_F1_RFC = random_search.best_score_
best_parameters_RFC = random_search.best_params_

print("\n")
print("SVC")

parameters = {'gamma': sp_randFloat(0.0001, 1),
                      'C': sp_randFloat(0.01, 100),
                      'class_weight': ['None', 'balanced'],
                      'kernel': ['rbf', 'sigmoid', 'linear', 'poly']}
random_search = RandomizedSearchCV(estimator= SVC(random_state=0, probability=True),
                                   param_distributions=parameters,
                                   scoring = 'f1',
                                   cv = loo,
                                   n_iter= 100,
                                   n_jobs= -1)
random_search.fit(X_train, Y_train)
best_F1_SVC = random_search.best_score_
best_parameters_SVC = random_search.best_params_


print("\n")
print("Logistic Regression")

parameters = {'C': sp_randFloat(0.0001, 100),
                  'max_iter': sp_randInt(2,500),
                  'class_weight': ['None', 'balanced']}
random_search = RandomizedSearchCV(estimator= LogisticRegression(random_state=0),
                               param_distributions=parameters,
                               scoring = 'f1',
                               cv = loo,
                               n_iter= 100,
                               n_jobs=-1)
random_search.fit(X_train, Y_train)
best_F1_LRC = random_search.best_score_
best_parameters_LRC = random_search.best_params_

print("\n")
print("MLP classifier")

parameters = {'alpha': sp_randFloat(0.0001, 0.1),
                  'max_iter': sp_randInt(200,500),
                  'learning_rate': ['constant', 'adaptive'],
                  'activation': ['logistic', 'tanh', 'relu'],
                  'hidden_layer_sizes': sp_randInt(1,150),
                  'solver': ['lbfgs', 'sgd', 'adam']}
random_search = RandomizedSearchCV(estimator= MLPClassifier(random_state=0),
                               param_distributions=parameters,
                               scoring = 'f1',
                               cv = loo,
                               n_iter=100,
                               n_jobs=-1)
random_search.fit(X_train, Y_train)
best_F1_MLP = random_search.best_score_
best_parameters_MLP = random_search.best_params_

print("\n")
print("Decision Tree Classifier")

parameters = {'min_samples_leaf': sp_randInt(2,15),
                  'max_depth': sp_randInt(2,30),
                  'max_features': ['log2', 'sqrt'],
                  'criterion': ['entropy', 'gini', 'log_loss'],
                  'class_weight': ['None', 'balanced']}

random_search= RandomizedSearchCV(estimator= DecisionTreeClassifier(random_state=0, splitter='best'),
                               param_distributions=parameters,
                               scoring = 'f1',
                               cv = loo,
                               n_iter= 100,
                               n_jobs=-1)
random_search.fit(X_train, Y_train)
best_F1_DTC = random_search.best_score_
best_parameters_DTC = random_search.best_params_

print("\n")
print("Gaussian Naive Bayes")

parameters = {'var_smoothing': sp_randFloat(1e-9, 1e-3)}
random_search = RandomizedSearchCV(estimator=GaussianNB(),
                               param_distributions=parameters,
                               scoring='f1',
                               cv=loo,
                               n_iter=100,
                               n_jobs=-1)

random_search.fit(X_train, Y_train)
best_F1_GNB = random_search.best_score_
best_parameters_GNB = random_search.best_params_


print("\n")
print("KNeighbors Classifier")

parameters ={'leaf_size': sp_randInt(1,50),
                 'n_neighbors': sp_randInt(1,10),
                 'p': sp_randInt(1,3),
                 'weights': ['uniform', 'distance'],
                 'algorithm': ['kd_tree', 'brute', 'ball_tree']}
random_search = RandomizedSearchCV(KNeighborsClassifier(),
                               param_distributions=parameters,
                               scoring = 'f1',
                               cv = loo,
                               n_iter=100,
                               n_jobs=-1)
random_search.fit(X_train, Y_train)
best_F1_KNN = random_search.best_score_
best_parameters_KNN = random_search.best_params_

print("RFC best F1")
print(best_F1_RFC)
print("RFC parameter")
print(best_parameters_RFC)

print("SVC best F1")
print(best_F1_SVC)
print("SVC parameter")
print(best_parameters_SVC)

print("LRC best F1")
print(best_F1_LRC)
print("LRC parameter")
print(best_parameters_LRC)

print("MLP best F1")
print(best_F1_MLP)
print("MLP parameter")
print(best_parameters_MLP)

print("DTC best F1")
print(best_F1_DTC)
print("DTC parameter")
print(best_parameters_DTC)

print("GNB best F1")
print(best_F1_GNB)
print("GNB parameter")
print(best_parameters_GNB)

print("KNN best F1")
print(best_F1_KNN)
print("KNN parameter")
print(best_parameters_KNN)
